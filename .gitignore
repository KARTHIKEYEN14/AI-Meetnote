# ========================
# Node Modules (NEVER commit these)
# ========================
node_modules/
**/node_modules/

# ========================
# Environment Variables (keep secrets safe)
# ========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ========================
# Build Output
# ========================
dist/
dist-ssr/
build/

# ========================
# Logs
# ========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================
# OS Files
# ========================
.DS_Store
Thumbs.db

# ========================
# Editor / IDE
# ========================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ========================
# Misc
# ========================
*.local

# ========================
# Uploads (user audio files — never commit)
# ========================
server/uploads/*
!server/uploads/.gitkeep
